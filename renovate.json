{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update versions in action.yaml",
      "managerFilePatterns": [
        "/^action.yaml$/"
      ],
      "matchStrings": [
        "# renovate: (?<datasource>.+?)\\s+default:\\s\\'(?<packageName>.+?):(?<currentValue>.+?)'\\s",
        "# renovate: (?<datasource>.+?) (?<packageName>.+?)\\s+default:\\s\\'(?<currentValue>.+?)'\\s",
        "# renovate: (?<datasource>.+?) (?<packageName>.+?) (?<registryUrl>.+?)\\s+default:\\s*(?<currentValue>.+?)\\s"
      ]
    },
    {
      "customType": "regex",
      "description": "Update k8s versions in GitHub workflow matrix",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "# renovate: (?<depName>\\S+)(?: allowedVersions=(?<allowedVersions>\\S+))?\\s+- \"(?<currentValue>.*?)\""
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "customDatasources": {
    "k8s": {
      "defaultRegistryUrlTemplate": "https://dl.k8s.io/release/stable.txt",
      "format": "plain"
    }
  },
  "packageRules": [
    {
      "description": "Group all kindest/node updates together",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "kindest/node"
      ],
      "groupName": "kubernetes versions",
      "separateMinorPatch": false,
      "automerge": false
    }
  ],
  "dependencyDashboard": true
}
